{
  "name": "shop-manager",
  "version": "1.1.7",
  "description": "RetailPro - Ứng dụng quản lý bán hàng",
  "main": "BE/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Khoi12122005",
        "repo": "quan-ly-cua-hang"
      }
    ]
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^9.6.0",
    "electron-updater": "^6.1.7",
    "xlsx": "^0.18.5"
  }
}
